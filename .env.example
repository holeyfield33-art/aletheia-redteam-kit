# Get your key at https://app.aletheia-core.com/keys
ALETHEIA_API_KEY=

# Simulated demo setting only; real deployments should never enable this.
ENABLE_UNSAFE_DEV_MODE=false

# Optional: override for self-hosted Aletheia (defaults to hosted)
# ALETHEIA_BASE_URL=https://api.aletheia-core.com

# Hosted dashboard auth (auto-detects basic/api-key/proxy when matching env vars are present)
# ALETHEIA_DASHBOARD_AUTH_MODE=auto
# ALETHEIA_DASHBOARD_USERNAME=aletheia
# Preferred for production: pre-generated bcrypt hash
# ALETHEIA_DASHBOARD_PASSWORD_HASH=$2b$12$replace.with.a.real.hash
# Backward-compatible fallback: plaintext password, hashed in memory at startup
# ALETHEIA_DASHBOARD_PASSWORD=change-me
# ALETHEIA_DASHBOARD_API_KEY_HEADER=X-API-Key
# Preferred for production: pre-generated bcrypt hash
# ALETHEIA_DASHBOARD_API_KEY_HASH=$2b$12$replace.with.a.real.hash
# Backward-compatible fallback: plaintext API key, hashed in memory at startup
# ALETHEIA_DASHBOARD_API_KEY=replace-with-operator-api-key
# ALETHEIA_DASHBOARD_SESSION_SECRET=replace-with-32-byte-random-secret
# ALETHEIA_DASHBOARD_SESSION_TTL_HOURS=12
# ALETHEIA_DASHBOARD_SECURE_COOKIES=true
# ALETHEIA_DASHBOARD_TRUST_PROXY_AUTH=false
# ALETHEIA_DASHBOARD_PROXY_USER_HEADER=X-Forwarded-User
# ALETHEIA_DASHBOARD_PROXY_AUTHORIZATION_HEADER=Authorization
